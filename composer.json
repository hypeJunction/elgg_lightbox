{
    "name": "hypejunction/elgg_lightbox",
    "version": "7.0.0",
    "type": "elgg-plugin",
    "description": "Enhanced lightbox for Elgg",
    "homepage": "https://github.com/hypeJunction/elgg_lightbox",
    "keywords": [
        "elgg",
        "plugin",
        "ui",
        "lightbox"
    ],
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "ext-intl": "*",
        "composer/installers": "^2.0",
        "elgg/elgg": "~7.0.0"
    },
    "autoload": {
        "psr-4": {
            "hypeJunction\\Lightbox\\": "classes/hypeJunction/Lightbox/"
        }
    },
    "extra": {
        "elgg-plugin": {
            "id": "elgg_lightbox"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ]
}
