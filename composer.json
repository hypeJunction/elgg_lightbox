{
	"name": "hypejunction/elgg_lightbox",
	"version": "4.0.0",
	"type": "elgg-plugin",
	"description": "Enhanced lightbox for Elgg",
	"homepage": "https://github.com/hypeJunction/elgg_lightbox",
	"keywords": [
		"elgg",
		"plugin",
		"ui",
		"lightbox"
	],
	"license": "GPL-2.0-or-later",
	"require": {
		"composer/installers": "^2.0",
		"php": ">=8.2",
		"elgg/elgg": "^6.0"
	},
	"autoload": {
		"psr-4": {
			"hypeJunction\\Lightbox\\": "classes/hypeJunction/Lightbox/"
		}
	},
	"extra": {
		"elgg-plugin": {
			"id": "elgg_lightbox"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
